# Frontend Environment Variables

# Leave unset in dev so requests use the Vite proxy (/restaurant -> localhost:5000).
# Set only for production, e.g. VITE_API_URL=https://api.yourdomain.com
# VITE_API_URL=http://localhost:5000

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CALLBACK_URL=google_callback_url

# Razorpay Key ID (for payment integration)
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID

# Note: Never commit actual credentials to version control
# Copy this file to .env and add your real values
